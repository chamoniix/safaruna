generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Required Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  
  // Safaruna specific fields
  role          Role      @default(PELERIN)
  firstName     String?
  lastName      String?
  phoneWhatsapp String?
  country       String?
  createdAt     DateTime  @default(now())
  lastLogin     DateTime?

  // Relations
  accounts       Account[]
  sessions       Session[]
  guideProfile   GuideProfile?
  
  // As a Pelerin
  reservations   Reservation[] @relation("PelerinReservations")
  conversationsAsPelerin Conversation[] @relation("PelerinConversations")
  messages       Message[]
  reviews        Review[]
  savedDuas      SavedDua[]
  courseProgress CourseProgress[]
  notifications  Notification[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  PELERIN
  GUIDE
  ADMIN
}

// Safaruna Core Models

model GuideProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug              String?  @unique
  bio               String? 
  city              String?
  nationality       String?
  experienceYears   Int?
  university        String?
  diplomaUrl        String?
  idDocUrl          String?
  videoUrl          String?
  ibanEncrypted     String?
  status            ProfileStatus @default(DRAFT)
  responseTimeAvg   String?
  completionRate    Int?     @default(0)
  commissionRate    Float    @default(0.15)
  interviewScore    Int?
  interviewNotes    String?
  interviewDate     DateTime?
  interviewedBy     String?

  // Relations
  packages          Package[]
  availabilities    Availability[]
  reservations      Reservation[] @relation("GuideReservations")
  conversationsAsGuide Conversation[] @relation("GuideConversations")
  languages         GuideLanguage[]
  places            GuidePlace[]
  transfers         Transfer[]
}

enum ProfileStatus {
  DRAFT
  REVIEW
  ACTIVE
  SUSPENDED
}

model GuideLanguage {
  id             String @id @default(cuid())
  guideProfileId String
  guideProfile   GuideProfile @relation(fields: [guideProfileId], references: [id], onDelete: Cascade)
  languageCode   String
  level          String // e.g., NATIVE, C2, B2
}

model GuidePlace {
  id             String      @id @default(cuid())
  guideProfileId String
  guideProfile   GuideProfile @relation(fields: [guideProfileId], references: [id], onDelete: Cascade)
  placeKey       String
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())

  @@unique([guideProfileId, placeKey])
}

model Place {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameFr      String
  nameAr      String?
  city        String
  category    String
  description String
  duaText     String?
}

model Package {
  id                 String   @id @default(cuid())
  guideProfileId     String
  guideProfile       GuideProfile @relation(fields: [guideProfileId], references: [id], onDelete: Cascade)
  name               String
  durationDays       Int
  pricePerPerson     Float
  priceGroup         Float?
  minPeople          Int      @default(1)
  maxPeople          Int
  cancellationPolicy String? 
  
  reservations       Reservation[]
}

model Availability {
  id             String   @id @default(cuid())
  guideProfileId String
  guideProfile   GuideProfile @relation(fields: [guideProfileId], references: [id], onDelete: Cascade)
  date           DateTime
  status         AvailabilityStatus @default(AVAILABLE)

  @@unique([guideProfileId, date])
}

enum AvailabilityStatus {
  AVAILABLE
  BOOKED
  UNAVAILABLE
}

model Reservation {
  id                String   @id @default(cuid())
  refNumber         String   @unique // SAF-2025-XXXXX
  pelerinId         String
  pelerin           User     @relation("PelerinReservations", fields: [pelerinId], references: [id])
  guideProfileId    String
  guideProfile      GuideProfile @relation("GuideReservations", fields: [guideProfileId], references: [id])
  packageId         String
  package           Package  @relation(fields: [packageId], references: [id])
  startDate         DateTime
  endDate           DateTime
  nbPeople          Int
  transportOption   String?
  optionsJson       Json?
  basePrice         Float
  commissionAmount  Float
  totalPrice        Float
  status            ReservationStatus @default(PENDING)
  stripePaymentId   String?
  notes             String?
  selectedPlaces    Json?
  selectedCities    String?
  withTransport     Boolean  @default(false)
  withCar           Boolean  @default(false)
  gender            String?
  langue            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  reviews           Review[]
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model PlacePrice {
  id       String  @id @default(cuid())
  placeKey String  @unique
  price    Float   @default(50)
  isActive Boolean @default(true)
}

// ---------------------------------------------------------
// MESSAGING SYSTEM
// ---------------------------------------------------------

model Conversation {
  id            String   @id @default(cuid())
  pelerinId     String
  pelerin       User     @relation("PelerinConversations", fields: [pelerinId], references: [id])
  guideProfileId String
  guideProfile  GuideProfile @relation("GuideConversations", fields: [guideProfileId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  messages      Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User     @relation(fields: [senderId], references: [id])
  content        String  
  readAt         DateTime?
  createdAt      DateTime @default(now())
}

model Review {
  id                 String   @id @default(cuid())
  reservationId      String
  reservation        Reservation @relation(fields: [reservationId], references: [id])
  pelerinId          String
  pelerin            User     @relation(fields: [pelerinId], references: [id])
  ratingOverall      Int
  ratingPunctuality  Int?
  ratingPedagogy     Int?
  ratingKnowledge    Int?
  comment            String  
  guideResponse      String? 
  createdAt          DateTime @default(now())
}

// ---------------------------------------------------------
// FINANCIAL: TRANSFERS
// ---------------------------------------------------------

model Transfer {
  id             String   @id @default(cuid())
  guideProfileId String
  guideProfile   GuideProfile @relation(fields: [guideProfileId], references: [id])
  amount         Float
  commission     Float
  net            Float
  period         String
  status         TransferStatus @default(PENDING)
  createdAt      DateTime @default(now())
}

enum TransferStatus {
  PENDING
  PROCESSING
  PAID
}

// ---------------------------------------------------------
// SPIRITUAL / DAILY TOOLS (THE 360° EXPERIENCE)
// ---------------------------------------------------------

model Course {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  category      String
  durationMin   Int
  level         String
  description   String? 
  videoUrl      String?
  thumbnailUrl  String?
  
  progress      CourseProgress[]
}

model CourseProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progressPct Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([userId, courseId])
}

model Dua {
  id              String   @id @default(cuid())
  category        String
  title           String?
  arabicText      String  
  transliteration String? 
  translationFr   String  
  source          String?
  audioUrl        String?
  
  savedBy         SavedDua[]
}

model SavedDua {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  duaId     String
  dua       Dua      @relation(fields: [duaId], references: [id], onDelete: Cascade)
  savedAt   DateTime @default(now())

  @@unique([userId, duaId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model ReservationDraft {
  id        String   @id @default(cuid())
  refNumber String   @unique
  data      String   // JSON stringifié
  expiresAt DateTime
  createdAt DateTime @default(now())
}
